# =============================================================================
# MORPH Configuration
# =============================================================================
# Copy this file to .env and update paths for your environment.
# All paths should be absolute Linux paths.

# =============================================================================
# Cowrie Paths (required)
# =============================================================================

# Path to Cowrie's JSON log file
COWRIE_LOG=/home/cowrie/cowrie/var/log/cowrie/cowrie.json

# Path to Cowrie's fake filesystem root
HONEYFS_ROOT=/home/cowrie/cowrie/honeyfs

# =============================================================================
# MORPH Directories (required)
# =============================================================================

# Where dossiers are stored (relative to project root is fine)
DOSSIERS_DIR=morph/dossiers

# Reactor log file path
REACTOR_LOG=reactor.log

# Deception module log file path  
DECEPTION_LOG=morph/deception.log

# Adaptor module log file path
ADAPTOR_LOG=morph/adaptor.log

# =============================================================================
# Flask Settings (optional)
# =============================================================================

# Flask debug mode (set to false in production)
FLASK_DEBUG=false

# Flask host (0.0.0.0 to allow external connections)
FLASK_HOST=127.0.0.1

# Flask port
FLASK_PORT=5000

# =============================================================================
# OSINT Settings (optional)
# =============================================================================

# ipinfo.io API token (optional - free tier works without token)
# Get one at: https://ipinfo.io/signup
IPINFO_TOKEN=

# Request timeout for OSINT queries (seconds)
OSINT_TIMEOUT=5
